{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    // The watch runs Moddable's XS engine (modern ES2025). Type-check against a
    // recent standard library; the real on-device build is driven by `pebble
    // build`, which generates its own tsconfig from the Moddable manifests.
    "target": "ES2024",
    "lib": ["ES2024"],
    "module": "ES2022",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "resolveJsonModule": true,

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    // tsc is used here only for editor/CI type-checking, never for emit.
    "noEmit": true
  }
}
