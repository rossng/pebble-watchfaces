{
  "name": "passing-trains",
  "version": "1.0.0",
  "private": true,
  "description": "A native Pebble C watchface that slowly pans along a random Dutch (NS) train, minute by minute, scaled to fill the screen.",
  "keywords": [
    "pebble-app"
  ],
  "author": "Ross Gardiner",
  "scripts": {
    "prepare:images": "node scripts/prepare-images.mjs",
    "build": "pebble build",
    "emulator": "pebble install --emulator emery",
    "dev": "pebble build && pebble install --emulator emery && node ../../tools/emu-tui/bin/emu-tui.js --emulator emery",
    "reset": "pebble kill && pebble wipe",
    "deploy:phone": "pebble install --phone \"$PEBBLE_PHONE\"",
    "deploy:cloud": "pebble install --cloudpebble",
    "publish:appstore": "pebble build && pebble publish"
  },
  "appStoreUrl": "https://apps.repebble.com/passing-trains_828038d2a34d45eb8b3daa37",
  "pebble": {
    "displayName": "Passing Trains",
    "uuid": "c26944b6-737b-4764-b719-240bbc6be77b",
    "sdkVersion": "3",
    "targetPlatforms": [
      "emery",
      "gabbro"
    ],
    "watchapp": {
      "watchface": true
    },
    "resources": {
